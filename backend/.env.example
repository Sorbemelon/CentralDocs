NODE_ENV=development
PORT=8080
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production clear-session cleanup removes workspace data without resetting usage
# so users cannot bypass quota limits by repeatedly clearing the demo.
DEMO_CLEAR_RESETS_USAGE=false
DEMO_QUOTA_WINDOW_DAYS=3

# The database name must be included before the query string.
# Without /centraldocs, Mongoose/MongoDB may use the default database such as test.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/centraldocs?retryWrites=true&w=majority&appName=CentralDocsCluster
MONGODB_DATABASE_NAME=centraldocs
MONGODB_VECTOR_INDEX_NAME=document_chunks_vector_index
MONGODB_VECTOR_PATH=embedding

AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=centraldocs-demo-bucket
AWS_ACCESS_KEY_ID=<replace-me>
AWS_SECRET_ACCESS_KEY=<replace-me>

AI_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_GENERATION_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_GENERATION_FALLBACK_MODEL_1=gemini-3-flash-preview
GEMINI_GENERATION_FALLBACK_MODEL_2=gemini-2.5-flash
GEMINI_API_KEY_1=<replace-me>
GEMINI_API_KEY_2=<replace-me>
GEMINI_API_KEY_3=<replace-me>
