NODE_ENV=development
PORT=4000
CLIENT_ORIGINS=http://localhost:5173

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=centraldocs

AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=centraldocs-demo-bucket
AWS_ACCESS_KEY_ID=<replace-me>
AWS_SECRET_ACCESS_KEY=<replace-me>

AI_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=768
GEMINI_GENERATION_PRIMARY=gemini-3.5-flash
GEMINI_GENERATION_FALLBACK_1=gemini-3-flash-preview
GEMINI_GENERATION_FALLBACK_2=gemini-2.5-flash
GEMINI_API_KEYS=<key1>,<key2>,<key3>

DEMO_SESSION_DAYS=3
DEMO_MAX_UPLOADS=5
DEMO_MAX_PROMPTS=10
DEMO_MAX_GENERATED_DOCS=3
DEMO_MAX_STORAGE_MB=20
